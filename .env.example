# Local development defaults
# This repository assumes:
# - local development uses SQLite
# - Vercel production uses hosted Postgres
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Internal auth and encryption
ADMIN_PASSWORD="change-me"
APP_ENCRYPTION_KEY="replace-with-32-byte-secret-value"
ADMIN_SESSION_SECRET="replace-with-a-long-random-session-secret"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional Meta defaults for bootstrapping the first environment
META_GRAPH_API_VERSION="v25.0"
META_APP_ID=""
META_APP_SECRET=""
META_USER_ACCESS_TOKEN=""
META_PAGE_ACCESS_TOKEN=""
META_SYSTEM_USER_TOKEN=""
META_DEFAULT_BUSINESS_ID=""
META_DEFAULT_PAGE_ID=""
META_DEFAULT_IG_USER_ID=""
DEFAULT_ENV_LABEL="Default"

REVIEW_PACK_FRESHNESS_HOURS="72"

# Production note:
# On Vercel use:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://..."
