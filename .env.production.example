# Production / Vercel example
# Recommended provider: Neon
# Alternative: Railway Postgres
DATABASE_PROVIDER="postgresql"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

ADMIN_PASSWORD="replace-with-strong-admin-password"
APP_ENCRYPTION_KEY="replace-with-32-byte-secret-value"
ADMIN_SESSION_SECRET="replace-with-a-long-random-session-secret"
NEXT_PUBLIC_APP_URL="https://your-vercel-app.vercel.app"

META_GRAPH_API_VERSION="v22.0"
META_APP_ID=""
META_APP_SECRET=""
META_USER_ACCESS_TOKEN=""
META_PAGE_ACCESS_TOKEN=""
META_SYSTEM_USER_TOKEN=""
META_DEFAULT_BUSINESS_ID=""
META_DEFAULT_PAGE_ID=""
META_DEFAULT_IG_USER_ID=""
DEFAULT_ENV_LABEL="Production"

REVIEW_PACK_FRESHNESS_HOURS="72"
